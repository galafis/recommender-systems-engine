# =============================================================================
# Recommender Systems Engine - Environment Variables
# =============================================================================

# Application
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# Model Configuration
DEFAULT_METHOD=hybrid
DEFAULT_K=10
CF_WEIGHT=0.6
CB_WEIGHT=0.4
SIMILARITY_METRIC=cosine
N_NEIGHBORS=20

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
MODEL_CACHE_PATH=models/cache

# API Settings
API_RATE_LIMIT=100
API_TIMEOUT=30
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
